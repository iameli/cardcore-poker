{
  "lexicon": 1,
  "id": "re.cardco.poker.defs",
  "defs": {
    "positionScalar": {
      "type": "object",
      "description": "A deck position and its associated lock decryption scalar.",
      "required": ["deckPosition", "scalar"],
      "properties": {
        "deckPosition": {
          "type": "integer",
          "minimum": 0,
          "maximum": 51
        },
        "scalar": {
          "type": "bytes",
          "maxLength": 32,
          "description": "Ristretto255 lock decryption scalar."
        }
      }
    },
    "commitSeed": {
      "type": "object",
      "description": "Commit a hashed seed for later verification.",
      "required": ["commitment"],
      "properties": {
        "commitment": {
          "type": "bytes",
          "maxLength": 32,
          "description": "BLAKE2b hash of the player's secret seed."
        }
      }
    },
    "shuffleDeck": {
      "type": "object",
      "description": "Encrypt all cards with shuffle key and permute.",
      "required": ["deck"],
      "properties": {
        "deck": {
          "type": "array",
          "description": "52 encrypted Ristretto255 points.",
          "minLength": 52,
          "maxLength": 52,
          "items": {
            "type": "bytes",
            "maxLength": 32
          }
        }
      }
    },
    "lockDeck": {
      "type": "object",
      "description": "Remove shuffle encryption and apply per-position lock keys.",
      "required": ["deck"],
      "properties": {
        "deck": {
          "type": "array",
          "description": "52 locked Ristretto255 points.",
          "minLength": 52,
          "maxLength": 52,
          "items": {
            "type": "bytes",
            "maxLength": 32
          }
        }
      }
    },
    "revealLockKey": {
      "type": "object",
      "description": "Reveal a per-position lock scalar to deal a card.",
      "required": ["deckPosition", "scalar"],
      "properties": {
        "deckPosition": {
          "type": "integer",
          "minimum": 0,
          "maximum": 51,
          "description": "Which card position in the deck is being revealed."
        },
        "scalar": {
          "type": "bytes",
          "maxLength": 32,
          "description": "Ristretto255 lock decryption scalar for this position."
        }
      }
    },
    "bet": {
      "type": "object",
      "description": "A betting action.",
      "required": ["action"],
      "properties": {
        "action": {
          "type": "string",
          "knownValues": ["fold", "check", "call", "allIn"],
          "description": "The betting action. For raises, use 'raise' with the amount field."
        },
        "amount": {
          "type": "integer",
          "minimum": 0,
          "description": "Raise amount (total, not incremental). Only present for raises."
        }
      }
    },
    "revealHand": {
      "type": "object",
      "description": "Reveal hole card lock keys at showdown.",
      "required": ["reveals"],
      "properties": {
        "reveals": {
          "type": "array",
          "description": "Lock key reveals for hole card positions.",
          "items": {
            "type": "ref",
            "ref": "#positionScalar"
          }
        }
      }
    },
    "verifySeed": {
      "type": "object",
      "description": "Reveal the secret seed for full game replay and verification.",
      "required": ["seed"],
      "properties": {
        "seed": {
          "type": "bytes",
          "maxLength": 256,
          "description": "The secret seed. BLAKE2b hash must match the earlier commitment."
        }
      }
    }
  }
}
