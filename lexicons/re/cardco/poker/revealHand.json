{
  "lexicon": 1,
  "id": "re.cardco.poker.revealHand",
  "defs": {
    "main": {
      "type": "record",
      "description": "Reveal hole card lock keys at showdown.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["table", "reveals", "createdAt"],
        "properties": {
          "table": {
            "type": "ref",
            "ref": "com.atproto.repo.strongRef"
          },
          "reveals": {
            "type": "array",
            "description": "Lock key reveals for hole card positions.",
            "items": {
              "type": "ref",
              "ref": "#positionScalar"
            }
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    },
    "positionScalar": {
      "type": "object",
      "required": ["deckPosition", "scalar"],
      "properties": {
        "deckPosition": {
          "type": "integer",
          "minimum": 0,
          "maximum": 51
        },
        "scalar": {
          "type": "bytes",
          "maxLength": 32,
          "description": "Ristretto255 lock decryption scalar."
        }
      }
    }
  }
}
