{
  "lexicon": 1,
  "id": "re.cardco.poker.action",
  "defs": {
    "main": {
      "type": "record",
      "description": "A single action in a poker hand. Key format: {table-tid}-{sequence-number}. Each action chains back to the previous via prev.",
      "key": "any",
      "record": {
        "type": "object",
        "required": ["table", "seq", "action", "createdAt"],
        "properties": {
          "table": {
            "type": "ref",
            "ref": "com.atproto.repo.strongRef",
            "description": "Reference to the table record for this hand."
          },
          "prev": {
            "type": "ref",
            "ref": "com.atproto.repo.strongRef",
            "description": "Reference to the previous action in this hand. Absent for the first action (seq 0)."
          },
          "seq": {
            "type": "integer",
            "minimum": 0,
            "description": "Action sequence number within this hand, starting from 0."
          },
          "action": {
            "type": "union",
            "refs": [
              "re.cardco.poker.defs#commitSeed",
              "re.cardco.poker.defs#shuffleDeck",
              "re.cardco.poker.defs#lockDeck",
              "re.cardco.poker.defs#revealLockKey",
              "re.cardco.poker.defs#bet",
              "re.cardco.poker.defs#revealHand",
              "re.cardco.poker.defs#verifySeed"
            ],
            "description": "The action payload."
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}
