{
  "lexicon": 1,
  "id": "re.cardco.poker.revealLockKey",
  "defs": {
    "main": {
      "type": "record",
      "description": "Reveal a per-position lock scalar to deal a card. Players create these during dealing rounds.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["table", "deckPosition", "scalar", "createdAt"],
        "properties": {
          "table": {
            "type": "ref",
            "ref": "com.atproto.repo.strongRef"
          },
          "deckPosition": {
            "type": "integer",
            "minimum": 0,
            "maximum": 51,
            "description": "Which card position in the deck is being revealed."
          },
          "scalar": {
            "type": "bytes",
            "maxLength": 32,
            "description": "Ristretto255 lock decryption scalar for this position."
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}
