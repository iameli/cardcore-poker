{
  "lexicon": 1,
  "id": "re.cardco.poker.verifySeed",
  "defs": {
    "main": {
      "type": "record",
      "description": "Reveal the secret seed after the hand for full game replay and verification.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["table", "seed", "createdAt"],
        "properties": {
          "table": {
            "type": "ref",
            "ref": "com.atproto.repo.strongRef"
          },
          "seed": {
            "type": "bytes",
            "maxLength": 256,
            "description": "The secret seed. BLAKE2b hash must match the earlier commitment."
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}
