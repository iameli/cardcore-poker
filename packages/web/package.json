{
  "name": "@cardcore/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:pds": "node ../dev-env/run.mjs",
    "dev:all": "concurrently -n pds,client -c blue,green \"pnpm run dev:pds\" \"pnpm run dev\"",
    "start": "pnpm run dev:all",
    "build": "vite build",
    "preview": "vite preview",
    "test": "playwright test",
    "test:headed": "PLAYWRIGHT_HEADED=1 playwright test"
  },
  "dependencies": {
    "@atcute/client": "^4.2.1",
    "@atcute/oauth-browser-client": "^3.0.0",
    "@ipld/car": "^5.4.3",
    "@ipld/dag-cbor": "^9.2.6",
    "cbor-x": "^1.6.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "concurrently": "^9.0.0",
    "playwright": "^1.59.1",
    "svelte": "^5.0.0",
    "vite": "^6.0.0"
  }
}
