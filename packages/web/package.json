{
  "name": "@cardcore/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:server": "node server/index.js",
    "dev:all": "concurrently -n server,client -c blue,green \"pnpm run dev:server\" \"pnpm run dev\"",
    "start": "pnpm run dev:all",
    "build": "vite build",
    "preview": "vite preview",
    "test": "playwright test",
    "test:headed": "playwright test --headed"
  },
  "dependencies": {
    "@atcute/client": "^4.2.1",
    "@atcute/oauth-browser-client": "^3.0.0",
    "@atproto/oauth-client-browser": "^0.3.0",
    "@ipld/dag-cbor": "^9.2.6",
    "express": "^4.21.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "concurrently": "^9.0.0",
    "playwright": "^1.59.1",
    "svelte": "^5.0.0",
    "vite": "^6.0.0"
  }
}
